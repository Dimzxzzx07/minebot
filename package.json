    "bot",
    "mc-bot",
    "osint",
    "Dimzxzzx07",
    "packet-sniffer",
    "stress-test",
    "minecraft-protocol",
    "automation",
    "headless-client",
    "security-audit",
    "network-engineering"
  ],
  "bugs": {
    "url": "https://github.com/dimzxzzx/minebot/issues"
  },
  "homepage": "https://github.com/dimzxzzx/minebot#readme",
  "license": "MIT",
  "dependencies": {
    "minecraft-protocol": "^1.64.0",
    "commander": "^11.1.0",
    "typed-emitter": "^1.0.0",
    "uuid-1345": "^1.0.2",
    "prismarine-nbt": "^2.0.0",
    "socks-proxy-agent": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2"
  }
