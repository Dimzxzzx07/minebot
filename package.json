  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mc-bot": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cli": "node dist/cli.js",
    "dev:cli": "ts-node src/cli.ts",
    "example": "ts-node examples/simple-bot.ts",
    "stress": "ts-node examples/stress-test.ts",
    "osint": "ts-node examples/osint-mode.ts",
    "clean": "rm -rf dist"
  },
  "author": "Dimzxzzx07",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dimzxzzx/minebot.git"
  },
  "keywords": [
